          Parameter {
            Variable      "Declarations"
            Value         "//================================================="
"============================\n"
"// Bibliotecas\n"
"//==========================================================================="
"==\n"
"\n"
"#include <stdlib.h>\n"
"#include <stdio.h>\n"
"#include <math.h>\n"
"#include <string.h>\n"
"\n"
"#define erro            Input(0)\n"
"#define Vd              Input(1)\n"
"#define P3f             Input(2)\n"
"#define Pref_carga      Input(3)\n"
"#define Pref_descarga   Input(4)\n"
"#define SOC             Input(5)\n"
"#define bess_cmd        Input(6)\n"
"\n"
"/*--------------------------------------------------------------------------*"
"/\n"
"/* Estados enviados pelo PMS                                                *"
"/\n"
"/*--------------------------------------------------------------------------*"
"/\n"
"\n"
"typedef enum\n"
"{\n"
"    BESS_IDLE = 0,\n"
"    BESS_CHARGE,\n"
"    BESS_DISCHARGE,\n"
"    BESS_FAULT\n"
"} bess_cmd_t;\n"
"\n"
"/*--------------------------------------------------------------------------*"
"/\n"
"/* PI                                                                     */"
"\n"
"/*--------------------------------------------------------------------------*"
"/\n"
"\n"
"typedef struct\n"
"{\n"
"    float Err;\n"
"    float Kp;\n"
"    float Up;\n"
"    float Ui;\n"
"    float OutMax;\n"
"    float OutMin;\n"
"    float Out;\n"
"    float Ki;\n"
"} PIDREG3;\n"
"\n"
"static PIDREG3 C_Vdc2;\n"
"static PIDREG3 C_P;\n"
"\n"
"static int cont_init = 0;\n"
"\n"
"float Pref = 0.0f;\n"
"float I_dref = 0.0f;\n"
"\n"
"/*--------------------------------------------------------------------------*"
"/\n"
"\n"
"void pid_reg3_calc(PIDREG3 *v)\n"
"{\n"
"    v->Up = v->Kp*v->Err;\n"
"\n"
"    v->Ui += v->Ki*v->Err;\n"
"\n"
"    if(v->Ui > v->OutMax)\n"
"        v->Ui = v->OutMax;\n"
"    else if(v->Ui < v->OutMin)\n"
"        v->Ui = v->OutMin;\n"
"\n"
"    v->Out = v->Up + v->Ui;\n"
"\n"
"    if(v->Out > v->OutMax)\n"
"        v->Out = v->OutMax;\n"
"    else if(v->Out < v->OutMin)\n"
"        v->Out = v->OutMin;\n"
"}\n"
"\n"
"/*--------------------------------------------------------------------------*"
"/\n"
"\n"
"void Setup_Controllers(void)\n"
"{\n"
"    C_Vdc2.Kp = -0.23204;\n"
"    C_Vdc2.Ki = -7.7123/6000.0;\n"
"\n"
"    C_Vdc2.OutMax = 0.0f;\n"
"    C_Vdc2.OutMin = 0.0f;\n"
"\n"
"    C_P.Kp = 0.0f;\n"
"    C_P.Ki = 19.098593171027442/6000.0;\n"
"\n"
"    C_P.OutMax = 1.5e5;\n"
"    C_P.OutMin = -1.5e5;\n"
"}"
            Show          off
          }
