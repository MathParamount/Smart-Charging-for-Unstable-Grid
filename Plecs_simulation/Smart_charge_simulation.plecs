          }
          Parameter {
            Variable      "NumZCSignals"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "DirectFeedthrough"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Ts"
            Value         "1/6000"
            Show          off
          }
          Parameter {
            Variable      "TerminalBasedSampleTimes"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Parameters"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#include <stdlib.h>\n"
"#include <stdio.h>\n"
"#include <math.h>\n"
"#include <string.h>\n"
"#define vref_a        Input(0)    // Tensao de referencia a\n"
"#define vref_b        Input(1)    // Tensao de referencia b\n"
"#define vref_c        Input(2)    // Tensao de referencia c\n"
"#define teta        Input(3)    //\n"
"\n"
"#define NOM_GRID_FREQ  60.0f                     \n"
"#define dois_pi        6.283185307179586f         \n"
"#define TSS        1.6666666666666666666666666666667e-4f     \n"
"#define dois_pi_div3   2.094395102393195492308428f  \n"
"\n"
"\n"
"typedef struct {\n"
"    float v0;\n"
"    float vd;\n"
"    float vq;\n"
"} dq0_t;\n"
"\n"
"static dq0_t dq0_f;\n"
"\n"
"void abc_to_0dq(dq0_t *dq0, float va, float vb, float vc, float rho)\n"
"{\n"
"    float cos_r   = cosf(rho);\n"
"    float cos_r_2 = cosf(rho - dois_pi_div3);\n"
"    float cos_r_4 = cosf(rho + dois_pi_div3);\n"
"    float sin_r   = sinf(rho);\n"
"    float sin_r_2 = sinf(rho - dois_pi_div3);\n"
"    float sin_r_4 = sinf(rho + dois_pi_div3);\n"
"    dq0->v0 = (2.0f/3.0f)*(0.5f*va + 0.5f*vb + 0.5f*vc);\n"
"    dq0->vd = (2.0f/3.0f)*( va*cos_r   + vb*cos_r_2 + vc*cos_r_4 );\n"
"    dq0->vq = (2.0f/3.0f)*(-va*sin_r   - vb*sin_r_2 - vc*sin_r_4 );\n"
"}"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "abc_to_0dq(&dq0_f, vref_a, vref_b,vref_c, teta);\n"
"\n"
"Output(0) = dq0_f.vd;      // Tensao eixo d\n"
"Output(1) = dq0_f.vq;      // Tensao eixo q"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
        }
